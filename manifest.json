{
  "manifest_version": 3,
  "name": "Prompt",
  "version": "1.0.0",
  "description": "Универсальный AI-ассистент для анализа веб-страниц, обработки изображений и чата с нейросетями через OpenAI-совместимый API.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "sidePanel",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.png", "*.jpg", "*.jpeg", "*.gif", "*.webp"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http: https:; connect-src 'self' http: https:;"
  },
  "action": {
    "default_title": "Открыть Prompt Panel"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file://*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
